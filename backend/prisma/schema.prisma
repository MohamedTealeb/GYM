// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  CLIENT
  TRAINER
}

enum PlanTier {
  PLUS
  PRO
  PREMIUM
}

enum PlanDuration {
  MONTH_1
  MONTH_3
  YEAR_1
}

enum FollowUpCadence {
  DAILY
  WEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum MonthlyPlanStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User{
   id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String
  phone     String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  isActive Boolean  @default(false)
  otp         String?
  otpExpires  DateTime?
  profileImage String?
  trainerProfile TrainerProfile?
  workouts       Workout[]
  progressLogs   Progress[]
   bodyPhotos      BodyPhoto[]  
  subscriptions UserSubscription[]
  monthlyPlansAsClient MonthlyPlan[] @relation("MonthlyPlanClient")
  monthlyPlansAsTrainer MonthlyPlan[] @relation("MonthlyPlanTrainer")
  monthlyPlanEdits MonthlyPlanEdit[]
  
}

model SubscriptionPlan {
  id              Int            @id @default(autoincrement())
  tier            PlanTier
  duration        PlanDuration
  price           Float
  isEnabled       Boolean        @default(true)
  salePrice       Float?
  saleStartsAt    DateTime?
  saleEndsAt      DateTime?
  followUpCadence FollowUpCadence
  maxPlanEditsPerMonth Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  userSubscriptions UserSubscription[]

  @@unique([tier, duration])
}

model UserSubscription {
  id        Int               @id @default(autoincrement())
  userId    Int
  planId    Int
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime          @default(now())
  endsAt    DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([planId])
}

model MonthlyPlan {
  id        Int              @id @default(autoincrement())
  clientId  Int
  trainerId Int
  monthStart DateTime
  status    MonthlyPlanStatus @default(DRAFT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  client  User @relation("MonthlyPlanClient", fields: [clientId], references: [id], onDelete: Cascade)
  trainer User @relation("MonthlyPlanTrainer", fields: [trainerId], references: [id], onDelete: Cascade)

  diet    DietPlan?
  workouts PlanWorkout[]
  edits   MonthlyPlanEdit[]
  progressLogs Progress[]
  bodyPhotos BodyPhoto[]

  @@unique([clientId, monthStart])
  @@index([trainerId])
}

model MonthlyPlanEdit {
  id          Int      @id @default(autoincrement())
  monthlyPlanId Int
  trainerId   Int
  createdAt   DateTime @default(now())

  monthlyPlan MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)
  trainer     User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([monthlyPlanId])
  @@index([trainerId])
  @@index([createdAt])
}

model DietPlan {
  id           Int       @id @default(autoincrement())
  monthlyPlanId Int      @unique
  targetCalories Int?
  proteinGrams  Int?
  carbsGrams    Int?
  fatGrams      Int?
  notes         String?

  monthlyPlan MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)
}

model PlanWorkout {
  id            Int       @id @default(autoincrement())
  monthlyPlanId Int
  title         String
  description   String?
  dayOfWeek     Int?      // 0..6 (optional)
  workoutDate   DateTime? // optional exact date
  createdAt     DateTime  @default(now())

  monthlyPlan MonthlyPlan @relation(fields: [monthlyPlanId], references: [id], onDelete: Cascade)
  exercises  PlanExercise[]

  @@index([monthlyPlanId])
}

model PlanExercise {
  id           Int    @id @default(autoincrement())
  planWorkoutId Int
  name         String
  sets         Int
  reps         Int
  restSeconds  Int?
  notes        String?

  workout PlanWorkout @relation(fields: [planWorkoutId], references: [id], onDelete: Cascade)

  @@index([planWorkoutId])
}
 model TrainerProfile {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  bio         String?
  experience  Int    
  specialty   String 
  price       Float

  user        User    @relation(fields: [userId], references: [id])
  clients     Workout[]
}
model Workout {
  id         Int      @id @default(autoincrement())
  clientId   Int
  trainerId  Int
  title      String
  description String?
  createdAt  DateTime @default(now())

  client     User     @relation(fields: [clientId], references: [id])
  trainer    TrainerProfile @relation(fields: [trainerId], references: [id])

  exercises  Exercise[]
}
model Exercise {
  id        Int    @id @default(autoincrement())
  name      String
  sets      Int
  reps      Int
  workoutId Int

  workout   Workout @relation(fields: [workoutId], references: [id],onDelete: Cascade)
}

model Progress {
  id        Int      @id @default(autoincrement())
  userId    Int
  monthlyPlanId Int?
  weight    Float?
  notes     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id] ,onDelete: Cascade)
  monthlyPlan MonthlyPlan? @relation(fields: [monthlyPlanId], references: [id], onDelete: SetNull)

  @@index([monthlyPlanId])
}
model BodyPhoto {
  id         Int      @id @default(autoincrement())
  imageUrl   String
  note       String?
  createdAt  DateTime @default(now())

  userId     Int
  monthlyPlanId Int?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyPlan MonthlyPlan? @relation(fields: [monthlyPlanId], references: [id], onDelete: SetNull)

  @@index([monthlyPlanId])
}